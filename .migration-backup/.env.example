# Public canonical host for metadata and generated files.
NEXT_PUBLIC_SITE_URL=https://www.jami.studio

# Analytics (marketing). Publishable client IDs — real values live only in the
# gitignored .env (and the Vercel project env). Leave these EMPTY in tracked files.
# PostHog marketing project (session replay + DOM autocapture OFF; explicit events).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
# GA4 marketing web stream (G-…).
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Deployment-only provider variables. Never commit real values.
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=
