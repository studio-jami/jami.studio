# Public canonical host for metadata and generated files.
NEXT_PUBLIC_SITE_URL=https://www.jami.studio

# Optional analytics provider settings. Values live in Vercel or the host secret store.
NEXT_PUBLIC_ANALYTICS_PROVIDER=
NEXT_PUBLIC_ANALYTICS_SITE_ID=

# Deployment-only provider variables. Never commit real values.
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=
